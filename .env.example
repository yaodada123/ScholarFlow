## DeerFlow TS environment example
## Copy to .env and fill in your own values:
##   cp .env.example .env
##
## 注意：请勿将真实密钥提交到公开仓库。

# ----------------------------
# Web (Next.js)
# ----------------------------
# Frontend uses this to call the backend API.
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Optional: enable "static website only" mode
# NEXT_PUBLIC_STATIC_WEBSITE_ONLY=false

# Optional: stream buffer size (bytes)
# NEXT_PUBLIC_MAX_STREAM_BUFFER_SIZE=1048576

# Optional: GitHub / analytics (server-side only, used by web)
# GITHUB_OAUTH_TOKEN=
# AMPLITUDE_API_KEY=

# ----------------------------
# Server (Fastify)
# ----------------------------
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# RAG provider (default: local). Set to lancedb to enable vector RAG.
RAG_PROVIDER=local

# LanceDB vector RAG (used when RAG_PROVIDER=lancedb)
LANCEDB_URI=data/lancedb
LANCEDB_TABLE=rag_chunks
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_MAX_CONTEXT_CHARS=12000

# Embeddings (OpenAI-compatible /embeddings endpoint, used by LanceDB RAG)
# EMBEDDING_MODEL__MODEL=text-embedding-3-small
# EMBEDDING_MODEL__API_KEY=sk-your-api-key
# EMBEDDING_MODEL__BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL__TIMEOUT_MS=60000
# EMBEDDING_MODEL__BATCH_SIZE=64
# EMBEDDING_MODEL__DIMENSIONS=1536

# Enable MCP server configuration endpoint
ENABLE_MCP_SERVER_CONFIGURATION=true

# Optional: server logging
# DEBUG=1

# ----------------------------
# LLM (OpenAI-compatible)
# At least one BASIC model is recommended.
# Supported keys:
#   <TYPE>_MODEL__MODEL
#   <TYPE>_MODEL__API_KEY
#   <TYPE>_MODEL__BASE_URL (or <TYPE>_MODEL__API_BASE)
#   <TYPE>_MODEL__TEMPERATURE
#   <TYPE>_MODEL__MAX_TOKENS
#   <TYPE>_MODEL__TIMEOUT_MS (or <TYPE>_MODEL__TIMEOUT)
# TYPE can be BASIC / REASONING / VISION / CODE
# ----------------------------
# DeepSeek sample: copy these into .env and fill in your key.
# BASIC_MODEL is used by default chat/planner/reporter flows.
BASIC_MODEL__MODEL=deepseek-chat
BASIC_MODEL__API_KEY=sk-your-deepseek-api-key
BASIC_MODEL__BASE_URL=https://api.deepseek.com
BASIC_MODEL__TEMPERATURE=0.3
BASIC_MODEL__MAX_TOKENS=8192
BASIC_MODEL__TIMEOUT_MS=120000

# Optional: reasoning model (used when "deep thinking" is enabled)
# REASONING_MODEL__MODEL=deepseek-reasoner
# REASONING_MODEL__API_KEY=sk-your-deepseek-api-key
# REASONING_MODEL__BASE_URL=https://api.deepseek.com
# REASONING_MODEL__TEMPERATURE=0.3
# REASONING_MODEL__MAX_TOKENS=8192
# REASONING_MODEL__TIMEOUT_MS=180000

# ----------------------------
# Web Search (optional)
# If not set, web search returns no results and the workflow will degrade gracefully.
# ----------------------------
# TAVILY_API_KEY=
